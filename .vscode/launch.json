    "configurations": [
        {
            "type": "PowerShell",
            "request": "launch",
            "name": "Debug ShowTree",
            "script": "${workspaceFolder}/tools/Debug-ShowTree.ps1",
            "args": [
                // ".",
                // ".\\TestAttributes\\FamilyRelations\\",
                "D:/show-tree/",
                // "D:\\",
                // "C:\\",
