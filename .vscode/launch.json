                "-Exclude SYMBOLS, .*",
                "-Include .vscode, .github",
                // "-Exclude SYMBOLS, .git",
                // "-Include .git*",
                // "-Ascii"
                // "-HideHidden",
                // "-Mono",
                "-Color",
